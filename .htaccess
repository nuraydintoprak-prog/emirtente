# ═══════════════════════════════════════════════════════════
#  Emir Tente — Apache .htaccess
#  Güvenlik · Performans · SEO · Google Ads Uyumluluğu
# ═══════════════════════════════════════════════════════════

# ── HTTPS Zorlaması (SSL varsa aktif et) ─────────────────
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www → non-www (canonical) ────────────────────────────
# RewriteEngine On
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ── Güvenlik Başlıkları ───────────────────────────────────
<IfModule mod_headers.c>
  # Clickjacking koruması
  Header always set X-Frame-Options "SAMEORIGIN"

  # MIME-type sniffing engeli (Google Ads uyumluluk için kritik)
  Header always set X-Content-Type-Options "nosniff"

  # XSS filtresi (eski tarayıcılar için)
  Header always set X-XSS-Protection "1; mode=block"

  # Referrer politikası
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # İzin politikası (Google Ads'ın gereksiz API erişimini engelle)
  Header always set Permissions-Policy "camera=(), microphone=(), payment=(), usb=()"

  # HSTS — HTTPS zorunlu (SSL kurulduktan sonra aktif et)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Content-Security-Policy — Google Ads + Google Analytics uyumlu
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://www.googletagmanager.com https://googleads.g.doubleclick.net https://www.google.com; connect-src 'self' https://www.google-analytics.com https://stats.g.doubleclick.net; frame-src https://bid.g.doubleclick.net https://td.doubleclick.net; object-src 'none'; base-uri 'self'; form-action 'self'"

  # Cache kontrol (HTML dosyaları — her zaman güncel)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Sıkıştırma (Gzip / Deflate) ──────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ── Tarayıcı Önbellekleme ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # AVIF / Görseller — 1 yıl
  ExpiresByType image/avif              "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"

  # CSS / JS — 1 ay
  ExpiresByType text/css                "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"

  # Fontlar — 1 yıl
  ExpiresByType font/woff               "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"

  # HTML — önbellek yok
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# ── AVIF MIME Tipi Desteği ────────────────────────────────
<IfModule mod_mime.c>
  AddType image/avif .avif
  AddType image/avif-sequence .avifs
</IfModule>

# ── Dizin Listelemeyi Kapat ───────────────────────────────
Options -Indexes

# ── Hassas Dosyaları Gizle ────────────────────────────────
<FilesMatch "(^\.htaccess|\.git|package\.json|package-lock\.json|node_modules)">
  Order allow,deny
  Deny from all
</FilesMatch>

# ── 404 Sayfası ───────────────────────────────────────────
ErrorDocument 404 /index.html

# ── ETag Kaldır (CDN uyumluluğu) ─────────────────────────
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
